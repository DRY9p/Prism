<section class="max-w-6xl mx-auto mb-20">
  <div class="text-center mb-14">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-white">Возможности PrismBI</h2>
    <p class="text-white/40 text-lg">Витрина данных, визуализация и контроль доступа — в одном контуре для бизнеса и аналитиков</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% [
      { icon: '⚡', title: 'Быстрые запросы к данным', desc: 'Оптимизированные витрины и кэширование: ответы на тяжёлые срезы без простоя интерфейса.' },
      { icon: '🔒', title: 'Безопасность и роли', desc: 'Модель доступа по ролям, аудит действий и разграничение строк и столбцов для чувствительных метрик.' },
      { icon: '📊', title: 'Дашборды и KPI', desc: 'Конструктор виджетов, целевые показатели и согласованные определения метрик для всех подразделений.' },
      { icon: '📱', title: 'Доступ с любого устройства', desc: 'Адаптивные отчёты и дашборды для руководителей в дороге и для команд в офисе.' },
      { icon: '🔄', title: 'Показатели в реальном времени', desc: 'Потоковое обновление ключевых метрик и оповещения при отклонении от плана.' },
      { icon: '🌐', title: 'Интеграции и API', desc: 'REST и выгрузки для внешних систем, встраивание виджетов и обмен с корпоративным контуром.' }
    ].each do |card| %>
      <%= render 'home/feature_card', card: card %>
    <% end %>
  </div>
</section>
