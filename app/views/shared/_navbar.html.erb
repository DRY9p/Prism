<nav data-controller="navbar" class="glass fixed top-4 left-1/2 -translate-x-1/2 w-[95%] max-w-5xl z-50 rounded-2xl px-6 py-4 flex items-center justify-between">
  <!-- Логотип -->
  <a href="#" class="flex items-center gap-3 group">
    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-blue-500 flex items-center justify-center shadow-lg shadow-purple-500/30 group-hover:shadow-purple-500/50 transition-shadow duration-300">
      <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <!-- Треугольная призма (основание) -->
        <polygon points="12,2 22,20 2,20" />
        <!-- Лучи спектра -->
        <line x1="12" y1="6" x2="12" y2="16" stroke="currentColor" opacity="0.6" stroke-width="1.5" />
        <line x1="8" y1="14" x2="6" y2="18" stroke="currentColor" opacity="0.4" stroke-width="1.5" />
        <line x1="16" y1="14" x2="18" y2="18" stroke="currentColor" opacity="0.4" stroke-width="1.5" />
        <!-- Свечение -->
        <circle cx="12" cy="11" r="1.5" fill="white" opacity="0.9" />
      </svg>
    </div>
    <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-white to-purple-200 bg-clip-text text-transparent">
      Prism<span class="text-purple-400">BI</span>
    </span>
  </a>

  <!-- Ссылки (десктоп) -->
  <div class="hidden md:flex items-center gap-1">
    <% {'Главная': root_path, 'Дашборды': '#', 'Отчёты': '#', 'О продукте': '#'}.each do |label, url| %>
      <%= link_to label, url, class: "px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200 #{current_page?(url) ? 'text-white bg-white/10' : 'text-white/70 hover:text-white hover:bg-white/10'}" %>
    <% end %>
  </div>

  <!-- Кнопки и мобильное меню -->
  <div class="flex items-center gap-3">
    <% if authenticated? %>
      <%= link_to "Выйти", session_path, data: { turbo_method: :delete }, class:"px-5 py-2.5 rounded-xl text-sm font-semibold bg-white text-gray gray-900 hover:bg-gray-100 shadow-lg shadow-white/10 hover:shadow-white/20 transition-all duration-300 active:scale-95" %>
    <% else %>
        <%= link_to "Войти", new_session_path, class: "px-5 py-2.5 rounded-xl text-sm font-semibold bg-white text-gray-900 hover:bg-gray-100 shadow-lg shadow-white/10 hover:shadow-white/20 transition-all duration-300 active:scale-95" %>
    <% end %>
    <!-- Бургер-меню (мобилка) -->
    <button data-action="click->navbar#toggle" aria-expanded="false" class="md:hidden p-2 rounded-xl hover:bg-white/10 transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <!-- Выпадающее мобильное меню -->
    <div data-navbar-target="menu" class="hidden absolute top-full left-0 right-0 mt-2 p-4 bg-[#1a1a1a]/95 backdrop-blur-xl rounded-2xl md:hidden flex-col gap-2 shadow-2xl border border-white/10">
      <% {'Главная': root_path, 'Дашборды': '#', 'Отчёты': '#', 'О продукте': '#'}.each do |label, url| %>
        <%= link_to label, url, class: "px-4 py-3 rounded-xl text-base font-medium text-white/70 hover:text-white hover:bg-white/10 transition-all duration-200" %>
      <% end %>
    </div>
  </div>
</nav>
