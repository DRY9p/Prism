<div>
  <%= form.label :email_address, "Email", class: "block text-sm font-medium text-white/70 mb-2" %>
  <%= form.email_field :email_address,
        required: true,
        autofocus: true,
        autocomplete: "username",
        placeholder: "you@company.ru",
        value: params[:email_address],
        class: "glass w-full px-5 py-3.5 rounded-xl text-white placeholder-white/30 outline-none focus:border-purple-400/60 focus:ring-2 focus:ring-purple-400/20 transition-all duration-300" %>
</div>

<div>
  <%= form.label :password, "Пароль", class: "block text-sm font-medium text-white/70 mb-2 mt-2" %>
  <%= form.password_field :password,
        required: true,
        autocomplete: "current-password",
        placeholder: "Введите пароль",
        maxlength: 72,
        class: "glass w-full px-5 py-3.5 rounded-xl text-white placeholder-white/30 outline-none focus:border-purple-400/60 focus:ring-2 focus:ring-purple-400/20 transition-all duration-300" %>
</div>