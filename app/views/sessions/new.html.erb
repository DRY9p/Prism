<section class="w-[95%] max-w-5xl mx-auto py-8">
  <div class="glass-light rounded-3xl p-8 sm:p-10 relative overflow-hidden text-center">
    <div class="absolute -top-20 -right-20 w-64 h-64 bg-purple-500/20 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10">
      <%= render "shared/flash" %>

      <h1 class="text-3xl sm:text-4xl font-bold mb-2 text-white">Вход в систему</h1>
      <p class="text-white/50 text-sm mb-8">Войдите, чтобы открыть дашборды и отчётность</p>

      <%= form_with url: session_url, class: "text-left space-y-5" do |form| %>
        <%= render "shared/auth_fields", form: form %>

        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-2 mt-4">
          <%= form.submit "Войти",
                class: "w-full sm:w-auto px-8 py-3.5 rounded-xl font-semibold text-lg bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white shadow-2xl shadow-purple-600/30 hover:shadow-purple-500/50 transition-all duration-300 active:scale-95 cursor-pointer" %>

          <%= link_to "Забыли пароль?", new_password_path,
                class: "text-sm text-white/50 hover:text-purple-300 transition-colors text-center sm:text-right" %>
        </div>
      <% end %>

      <p class="text-xs text-white/25 mt-8">
        Нет аккаунта?
        <%= link_to "Зарегистрироваться", new_registration_path, class: "text-purple-300 hover:text-purple-200 transition-colors" %>
      </p>
    </div>
  </div>
</section>
